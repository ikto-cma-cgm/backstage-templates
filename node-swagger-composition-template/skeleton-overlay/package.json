{
  "name": "${{ values.name }}",
  "version": "0.1.0",
  "description": "${{ values.description }}",
  "main": "dist/index.js",
  "engines": {
    "node": "${{ values.nodeVersion }}"
  },
  "scripts": {
    "fetch-spec": "node scripts/fetch-spec.mjs",
    "generate": "openapi-typescript src/api/openapi.yaml -o src/api/types.ts",
    "predev": "npm run generate",
    "dev": "ts-node src/index.ts",
    "prebuild": "npm run generate",
    "build": "tsc",
    "postbuild": "node -e \"require('fs').mkdirSync('dist/api',{recursive:true});require('fs').copyFileSync('src/api/openapi.yaml','dist/api/openapi.yaml')\"",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-openapi-validator": "^5.3.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^18.0.0",
    "openapi-typescript": "^6.7.6",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}

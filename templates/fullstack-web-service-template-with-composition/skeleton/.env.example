# =====================================
# Backend Configuration
# =====================================
NODE_ENV=development
PORT=${{ values.backendPort }}
LOG_LEVEL=info

# API Configuration
API_PREFIX=/api/v1

# CORS Configuration (allow requests from frontend)
CORS_ORIGIN=http://localhost:${{ values.frontendPort }}

{% if values.includeDatabase %}
# =====================================
# Database Configuration
# =====================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/${{ values.name }}
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false
{% endif %}

{% if values.includeRedis %}
# =====================================
# Redis Configuration
# =====================================
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600
REDIS_PREFIX=${{ values.name }}:
{% endif %}

# =====================================
# Frontend Configuration
# =====================================
# Public variables (exposed to browser - prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:${{ values.backendPort }}/api/v1
NEXT_PUBLIC_APP_NAME=${{ values.name }}
NEXT_PUBLIC_APP_VERSION=1.0.0

# Private variables (server-side only in Next.js)
# These are NOT exposed to the browser
SECRET_KEY=change-this-in-production

# =====================================
# Optional: Authentication (if implementing JWT)
# =====================================
# JWT_SECRET=your-secret-key-change-in-production
# JWT_EXPIRES_IN=7d
# JWT_REFRESH_EXPIRES_IN=30d

# =====================================
# Optional: Email Configuration
# =====================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@${{ values.name }}.com

# =====================================
# Optional: AWS Configuration
# =====================================
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=your-bucket-name

# =====================================
# Optional: Monitoring & Analytics
# =====================================
# SENTRY_DSN=https://your-sentry-dsn
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# =====================================
# Development Tools
# =====================================
# Set to true to enable debug mode
DEBUG=false
VERBOSE_LOGS=false

{
  "name": "${{ values.name }}",
  "version": "1.0.0",
  "description": "${{ values.description }}",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "echo 'No build step required for Node.js'",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"*.{json,md,yml,yaml}\"",
    "format:check": "prettier --check \"src/**/*.js\" \"*.{json,md,yml,yaml}\"",
    "prepare": "husky install",
    "validate": "npm run format:check && npm run lint",
    {%- if values.enableDocker %}
    "docker:build": "docker build -t ${{ values.name }} .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "logs": "docker-compose logs -f",
    {%- endif %}
    "test": "echo 'No tests configured yet' && exit 0"
  },
  "keywords": [
    "nodejs",
    "express",
    "api",
    "microservice",
    "backstage",
    "${{ values.name }}"
  ],
  "author": "${{ values.owner }}",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "swagger-ui-express": "^5.0.0",
    "yamljs": "^0.3.0",
    "express-async-errors": "^3.1.1",
    "joi": "^17.11.0"{%- if values.enablePrometheus %},
    "prom-client": "^15.1.0"
    {%- endif %}{%- if values.enableSentry %},
    "@sentry/node": "^7.99.0",
    "@sentry/tracing": "^7.99.0"
    {%- endif %}{%- if values.includeDatabase %},
    "pg": "^8.11.3",
    "knex": "^3.1.0"
    {%- endif %}{%- if values.includeRedis %},
    "redis": "^4.6.12"
    {%- endif %}
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0"
  },
  "engines": {
    "node": ">=${{ values.nodeVersion }}",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/${{ values.destination.owner }}/${{ values.destination.repo }}.git"
  },
  "bugs": {
    "url": "https://github.com/${{ values.destination.owner }}/${{ values.destination.repo }}/issues"
  },
  "homepage": "https://github.com/${{ values.destination.owner }}/${{ values.destination.repo }}#readme"
}

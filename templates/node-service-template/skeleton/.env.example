# Application Configuration
NODE_ENV=development
PORT=${{ values.port }}

# Logging
LOG_LEVEL=${{ values.logLevel }}
LOG_FORMAT=json

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Service Metadata
SERVICE_NAME=${{ values.name }}
SERVICE_VERSION=1.0.0
SERVICE_DESCRIPTION=${{ values.description }}
{%- if values.includeDatabase %}

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=${{ values.name | replace("-", "_") }}
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10
{%- else %}

# Database Configuration (uncomment if needed)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=${{ values.name | replace("-", "_") }}
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_SSL=false
# DB_POOL_MIN=2
# DB_POOL_MAX=10
{%- endif %}
{%- if values.includeRedis %}

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
{%- else %}

# Redis Configuration (uncomment if needed)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
{%- endif %}

# JWT Configuration (uncomment if needed)
# JWT_SECRET=your-secret-key-change-this
# JWT_EXPIRES_IN=7d
# JWT_REFRESH_EXPIRES_IN=30d

# External Services (uncomment if needed)
# EXTERNAL_API_URL=https://api.example.com
# EXTERNAL_API_KEY=your-api-key

# Feature Flags
FEATURE_EXAMPLE=false
{%- if values.enableSentry %}

# Sentry Configuration (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0
{%- else %}

# Monitoring and Observability (uncomment if needed)
# SENTRY_DSN=
{%- endif %}
{%- if values.enablePrometheus %}

# Metrics Configuration
METRICS_ENABLED=true
METRICS_PATH=/metrics
{%- endif %}

# Application Configuration
NODE_ENV=development
PORT=3000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Service Metadata
SERVICE_NAME=node-service-template
SERVICE_VERSION=1.0.0
SERVICE_DESCRIPTION=A production-ready Node.js service template

# Database Configuration (uncomment if needed)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=nodeservice
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_SSL=false
# DB_POOL_MIN=2
# DB_POOL_MAX=10

# Redis Configuration (uncomment if needed)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# JWT Configuration (uncomment if needed)
# JWT_SECRET=your-secret-key-change-this
# JWT_EXPIRES_IN=7d
# JWT_REFRESH_EXPIRES_IN=30d

# External Services (uncomment if needed)
# EXTERNAL_API_URL=https://api.example.com
# EXTERNAL_API_KEY=your-api-key

# Feature Flags (uncomment if needed)
# FEATURE_NEW_API=true
# FEATURE_EXPERIMENTAL=false

# Monitoring and Observability (uncomment if needed)
# SENTRY_DSN=
# DATADOG_API_KEY=
# NEW_RELIC_LICENSE_KEY=

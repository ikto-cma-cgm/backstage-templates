{
  "name": "${{ values.name }}",
  "version": "1.0.0",
  "description": "${{ values.description }}",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint ."
    {%- if values.testingFramework == 'vitest' %},
    "test": "vitest run",
    "test:watch": "vitest run --watch",
    "test:ui": "vitest --ui"{%- if values.includeCoverage %},
    "test:coverage": "vitest run --coverage"
    {%- endif %}
    {%- endif %}
    {%- if values.testingFramework == 'jest' %},
    "test": "jest",
    "test:watch": "jest --watch"{%- if values.includeCoverage %},
    "test:coverage": "jest --coverage"
    {%- endif %}
    {%- endif %}
    {%- if values.e2eFramework == 'playwright' %},
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
    {%- endif %}
    {%- if values.e2eFramework == 'cypress' %},
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:e2e:headless": "cypress run --headless"
    {%- endif %}
  },
  "keywords": [
    "react",
    "nextjs",
    "typescript",
    "frontend",
    "backstage",
    "${{ values.name }}"
  ],
  "author": "${{ values.owner }}",
  "license": "MIT",
  "dependencies": {
    "next": "16.0.10",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0",
    "class-variance-authority": "^0.7.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.0.10",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
    {%- if values.testingFramework != 'none' %},
    "@testing-library/react": "^16.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1"
    {%- endif %}
    {%- if values.testingFramework == 'vitest' %},
    "vitest": "^2.1.9",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^2.1.9",
    "jsdom": "^25.0.1"
    {%- endif %}
    {%- if values.testingFramework == 'jest' %},
    "jest": "^30.2.0",
    "@types/jest": "^30.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "identity-obj-proxy": "^3.0.0"
    {%- endif %}
    {%- if values.e2eFramework == 'playwright' %},
    "@playwright/test": "^1.57.0"
    {%- endif %}
    {%- if values.e2eFramework == 'cypress' %},
    "cypress": "^15.8.0"
    {%- endif %}
    {%- if values.includeCoverage and values.testingFramework == 'vitest' %},
    "@vitest/coverage-v8": "^2.1.9"
    {%- endif %}
    {%- if values.includeCoverage and values.testingFramework == 'jest' %},
    "istanbul-lib-coverage": "^3.2.2"
    {%- endif %}
    {%- if values.includeCoverage and values.e2eFramework == 'cypress' %},
    "@cypress/code-coverage": "^3.14.7"
    {%- endif %}
    {%- if values.errorTracking == 'sentry' %},
    "@sentry/react": "^10.31.0",
    "@sentry/nextjs": "^10.31.0"
    {%- endif %}
  },
  "engines": {
    "node": ">=${{ values.nodeJsVersion }}",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/${{ values.destination.owner }}/${{ values.destination.repo }}.git"
  },
  "bugs": {
    "url": "https://github.com/${{ values.destination.owner }}/${{ values.destination.repo }}/issues"
  },
  "homepage": "https://github.com/${{ values.destination.owner }}/${{ values.destination.repo }}#readme"
}

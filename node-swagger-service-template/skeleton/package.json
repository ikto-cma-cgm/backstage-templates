{
  "name": "${{ values.name }}",
  "version": "1.0.0",
  "description": "${{ values.description }}",
  "main": "dist/index.js",
  "openApiSpec": "${{ values.swaggerUrl }}",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "generate:api": "curl -o src/api/openapi.yaml '${{ values.swaggerUrl }}' && npx @openapitools/openapi-generator-cli generate -i ${{ values.swaggerUrl }} -g typescript-axios -o src/api/generated --additional-properties=useSingleRequestParameter=true,withSeparateModelsAndApi=true,apiPackage=api,modelPackage=models",
    "generate:controllers": "npx @openapitools/openapi-generator-cli generate -i ${{ values.swaggerUrl }} -g typescript-express-server -o src/api/express-generated"
  },
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "winston": "^3.17.0",
    "dotenv": "^16.4.7",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.6.1",
    "express-validator": "^7.2.1",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^22.13.1",
    "@types/express": "^5.0.1",
    "@types/cors": "^2.8.17",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/jest": "^29.5.14",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2",
    "eslint": "^9.20.1",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "supertest": "^7.0.0",
    "@openapitools/openapi-generator-cli": "^2.19.0"
  }
}


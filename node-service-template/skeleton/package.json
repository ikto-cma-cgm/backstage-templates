{
  "name": "${{ values.name }}",
  "version": "1.0.0",
  "description": "${{ values.description }}",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "express": "^${{ values.expressVersion }}",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "winston": "^3.17.0",
    "dotenv": "^16.4.7",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "typescript": "^${{ values.typescriptVersion }}",
    "@types/node": "^22.13.1",
    "@types/express": "^5.0.1",
    "@types/cors": "^2.8.17",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/jest": "^29.5.14",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2",
    "eslint": "^9.20.1",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "supertest": "^7.0.0"
  }
}
